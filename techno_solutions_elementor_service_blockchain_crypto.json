            {
              "id": "details_intro_bc",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<h2 style=\"font-family: 'Verdana', sans-serif; font-size: 28px; font-weight: 700; color: #1B1B1B; margin-bottom: 20px; line-height: 1.3;\">Consensus Engines & Distributed Cryptography</h2><p style=\"font-family: 'Verdana', sans-serif; font-size: 15px; color: #5B6470; line-height: 1.7; margin-bottom: 16px;\">At TECHNO-SOLUTIONS, we build decentralized architectures that establish immutable trust, automate multi-party compliance, and protect vital transaction logs. From deploying audited smart contracts to building custom Web3 portals and token networks, we help organizations eliminate single-point operational failures.</p><p style=\"font-family: 'Verdana', sans-serif; font-size: 15px; color: #5B6470; line-height: 1.7; margin-bottom: 30px;\">Our engineering depth guarantees zero vendor lock-in. We rely strictly on standardized distributed ledger tech frameworks to design future-proof protocols and interoperability suites across private consortium setups or public chain ecosystems.</p>"
              }
            },
            {
              "id": "details_highlights_bc",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<h3 style=\"font-family: 'Verdana', sans-serif; font-size: 18px; font-weight: 700; color: #0F2D63; margin-bottom: 16px;\">Web3 Capabilities & Protocols</h3><div style=\"display: grid; grid-template-columns: 1fr; gap: 12px; margin-bottom: 35px;\">  <div style=\"display: flex; align-items: start; gap: 12px;\">    <div style=\"background-color: rgba(229, 175, 43, 0.1); color: #E5AF2B; border-radius: 50%; padding: 4px; display: flex; align-items: center; justify-content: center; shrink: 0; width: 22px; height: 22px; box-sizing: border-box;\">      <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>    </div>    <span style=\"font-family: 'Verdana', sans-serif; font-size: 14px; color: #1B1B1B; line-height: 1.5;\">Audited Smart Contracts Development & Deployment (Solidity, Rust)</span>  </div>  <div style=\"display: flex; align-items: start; gap: 12px;\">    <div style=\"background-color: rgba(229, 175, 43, 0.1); color: #E5AF2B; border-radius: 50%; padding: 4px; display: flex; align-items: center; justify-content: center; shrink: 0; width: 22px; height: 22px; box-sizing: border-box;\">      <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>    </div>    <span style=\"font-family: 'Verdana', sans-serif; font-size: 14px; color: #1B1B1B; line-height: 1.5;\">Consortium private ledger setups (Hyperledger, private EVM nets)</span>  </div>  <div style=\"display: flex; align-items: start; gap: 12px;\">    <div style=\"background-color: rgba(229, 175, 43, 0.1); color: #E5AF2B; border-radius: 50%; padding: 4px; display: flex; align-items: center; justify-content: center; shrink: 0; width: 22px; height: 22px; box-sizing: border-box;\">      <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>    </div>    <span style=\"font-family: 'Verdana', sans-serif; font-size: 14px; color: #1B1B1B; line-height: 1.5;\">Digital asset tokenization (ERC-20, ERC-721, security tokens)</span>  </div>  <div style=\"display: flex; align-items: start; gap: 12px;\">    <div style=\"background-color: rgba(229, 175, 43, 0.1); color: #E5AF2B; border-radius: 50%; padding: 4px; display: flex; align-items: center; justify-content: center; shrink: 0; width: 22px; height: 22px; box-sizing: border-box;\">      <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>    </div>    <span style=\"font-family: 'Verdana', sans-serif; font-size: 14px; color: #1B1B1B; line-height: 1.5;\">Supply chain ledger tracking & end-to-end provenance audits</span>  </div>  <div style=\"display: flex; align-items: start; gap: 12px;\">    <div style=\"background-color: rgba(229, 175, 43, 0.1); color: #E5AF2B; border-radius: 50%; padding: 4px; display: flex; align-items: center; justify-content: center; shrink: 0; width: 22px; height: 22px; box-sizing: border-box;\">      <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>    </div>    <span style=\"font-family: 'Verdana', sans-serif; font-size: 14px; color: #1B1B1B; line-height: 1.5;\">Decentralized Identity solutions (DID) & crypto wallet APIs</span>  </div></div>"
              }
