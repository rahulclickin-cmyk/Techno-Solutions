                "editor": "<h3 style=\"font-family: 'Verdana', sans-serif; font-size: 18px; font-weight: 700; color: #0F2D63; margin-bottom: 16px;\">Core AI Solutions & Services</h3><div style=\"display: grid; grid-template-columns: 1fr; gap: 12px; margin-bottom: 35px;\">  <div style=\"display: flex; align-items: start; gap: 12px;\">    <div style=\"background-color: rgba(229, 175, 43, 0.1); color: #E5AF2B; border-radius: 50%; padding: 4px; display: flex; align-items: center; justify-content: center; shrink: 0; width: 22px; height: 22px; box-sizing: border-box;\">      <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>    </div>    <span style=\"font-family: 'Verdana', sans-serif; font-size: 14px; color: #1B1B1B; line-height: 1.5;\">AI Strategy & Consulting (AI Readiness & Roadmap Design)</span>  </div>  <div style=\"display: flex; align-items: start; gap: 12px;\">    <div style=\"background-color: rgba(229, 175, 43, 0.1); color: #E5AF2B; border-radius: 50%; padding: 4px; display: flex; align-items: center; justify-content: center; shrink: 0; width: 22px; height: 22px; box-sizing: border-box;\">      <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>    </div>    <span style=\"font-family: 'Verdana', sans-serif; font-size: 14px; color: #1B1B1B; line-height: 1.5;\">Custom AI Software & Model Development (LLMs, Neural Nets)</span>  </div>  <div style=\"display: flex; align-items: start; gap: 12px;\">    <div style=\"background-color: rgba(229, 175, 43, 0.1); color: #E5AF2B; border-radius: 50%; padding: 4px; display: flex; align-items: center; justify-content: center; shrink: 0; width: 22px; height: 22px; box-sizing: border-box;\">      <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>    </div>    <span style=\"font-family: 'Verdana', sans-serif; font-size: 14px; color: #1B1B1B; line-height: 1.5;\">Corporate AI Training & Hands-on Upskilling Workshops</span>  </div>  <div style=\"display: flex; align-items: start; gap: 12px;\">    <div style=\"background-color: rgba(229, 175, 43, 0.1); color: #E5AF2B; border-radius: 50%; padding: 4px; display: flex; align-items: center; justify-content: center; shrink: 0; width: 22px; height: 22px; box-sizing: border-box;\">      <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>    </div>    <span style=\"font-family: 'Verdana', sans-serif; font-size: 14px; color: #1B1B1B; line-height: 1.5;\">Predictive Analytics & Enterprise Data Science Solutions</span>  </div>  <div style=\"display: flex; align-items: start; gap: 12px;\">    <div style=\"background-color: rgba(229, 175, 43, 0.1); color: #E5AF2B; border-radius: 50%; padding: 4px; display: flex; align-items: center; justify-content: center; shrink: 0; width: 22px; height: 22px; box-sizing: border-box;\">      <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>    </div>    <span style=\"font-family: 'Verdana', sans-serif; font-size: 14px; color: #1B1B1B; line-height: 1.5;\">AI Governance, Ethics, Compliance & Security Standards</span>  </div></div>"
