            {
              "id": "about_intro_text",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p>Techno-Solutions, led by Sanjeev Goel, is a premier consulting and technology integration firm based in Delhi NCR. We bring deep, interdisciplinary expertise across both software systems (AI, Automation, Blockchain) and hardware/green infrastructure systems (Smart Homes, Solar Energy).</p><p>We believe that modern organizations shouldn't have to piece together separate vendors for software automation and hardware engineering. Our unified approach delivers robust, enterprise-grade systems with single-point accountability.</p>"
              }
            }
          ]
        },
        {
          "id": "about_intro_right",
          "elType": "column",
          "settings": {
            "_column_size": 50
          },
          "elements": [
            {
              "id": "about_intro_bio_box",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<div style='background-color: #F8F9FC; border: 1px solid #ECECEC; padding: 40px; border-radius: 24px;'><div style='display: flex; align-items: center; gap: 20px; margin-bottom: 20px;'><img src='https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?auto=format&fit=crop&w=150&q=80' style='width: 80px; height: 80px; border-radius: 50%; object-fit: cover;' /><div><h4 style='font-size: 20px; font-weight: 700; color: #1B1B1B; margin: 0;'>Sanjeev Goel</h4><p style='color: #E5AF2B; font-weight: 700; font-size: 12px; margin: 5px 0 0 0;'>FOUNDER & CHIEF CONSULTANT</p></div></div><p style='font-size: 14px; color: #5B6470; line-height: 1.7;'>Sanjeev is an experienced technology architect and systems integration pioneer. He leads Techno-Solutions with a mission to help Indian businesses and homeowners leverage modern automation, robust smart frameworks, and high-performance solar utilities safely, efficiently, and with premium outcomes.</p><div style='border-top: 1px solid #ECECEC; padding-top: 15px; margin-top: 15px; font-size: 13px; color: #5B6470;'><p style='margin: 5px 0;'><strong>📍 Location:</strong> Delhi, Noida, Gurgaon, India</p><p style='margin: 5px 0;'><strong>📞 Direct Phone:</strong> +91 9811841782</p><p style='margin: 5px 0;'><strong>✉️ Direct Email:</strong> info2sanjeev@gmail.com</p></div></div>"
              }
            }
          ]
        }
