          },
          "elements": [
            {
              "id": "details_intro_ba",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<h2 style=\"font-family: 'Verdana', sans-serif; font-size: 28px; font-weight: 700; color: #1B1B1B; margin-bottom: 20px; line-height: 1.3;\">Operational Excellence through Intelligent Workflows</h2><p style=\"font-family: 'Verdana', sans-serif; font-size: 15px; color: #5B6470; line-height: 1.7; margin-bottom: 16px;\">TECHNO-SOLUTIONS is a leading provider of Business Automation Solutions. We help startups, SMEs, large enterprises, and public organizations streamline operations, eliminate repetitive tasks, improve productivity, reduce operational costs, and accelerate digital transformation.</p><p style=\"font-family: 'Verdana', sans-serif; font-size: 15px; color: #5B6470; line-height: 1.7; margin-bottom: 30px;\">We combine business consulting expertise with Artificial Intelligence (AI), Robotic Process Automation (RPA), Cloud Computing, Low-Code Platforms, and Intelligent Workflow Automation to create future-ready, agile organizations.</p>"
              }
            },
            {
              "id": "details_highlights_ba",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<h3 style=\"font-family: 'Verdana', sans-serif; font-size: 18px; font-weight: 700; color: #0F2D63; margin-bottom: 16px;\">Core Capabilities & Integrations</h3><div style=\"display: grid; grid-template-columns: 1fr; gap: 12px; margin-bottom: 35px;\">  <div style=\"display: flex; align-items: start; gap: 12px;\">    <div style=\"background-color: rgba(229, 175, 43, 0.1); color: #E5AF2B; border-radius: 50%; padding: 4px; display: flex; align-items: center; justify-content: center; shrink: 0; width: 22px; height: 22px; box-sizing: border-box;\">      <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>    </div>    <span style=\"font-family: 'Verdana', sans-serif; font-size: 14px; color: #1B1B1B; line-height: 1.5;\">Business Process Automation (Workflows, Approval routing, Digital forms)</span>  </div>  <div style=\"display: flex; align-items: start; gap: 12px;\">    <div style=\"background-color: rgba(229, 175, 43, 0.1); color: #E5AF2B; border-radius: 50%; padding: 4px; display: flex; align-items: center; justify-content: center; shrink: 0; width: 22px; height: 22px; box-sizing: border-box;\">      <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>    </div>    <span style=\"font-family: 'Verdana', sans-serif; font-size: 14px; color: #1B1B1B; line-height: 1.5;\">Robotic Process Automation (RPA for Data Entry, Payroll, Reconciliations)</span>  </div>  <div style=\"display: flex; align-items: start; gap: 12px;\">    <div style=\"background-color: rgba(229, 175, 43, 0.1); color: #E5AF2B; border-radius: 50%; padding: 4px; display: flex; align-items: center; justify-content: center; shrink: 0; width: 22px; height: 22px; box-sizing: border-box;\">      <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>    </div>    <span style=\"font-family: 'Verdana', sans-serif; font-size: 14px; color: #1B1B1B; line-height: 1.5;\">Artificial Intelligence Automation (AI Chatbots, AI Agents, Intelligent OCR)</span>  </div>  <div style=\"display: flex; align-items: start; gap: 12px;\">    <div style=\"background-color: rgba(229, 175, 43, 0.1); color: #E5AF2B; border-radius: 50%; padding: 4px; display: flex; align-items: center; justify-content: center; shrink: 0; width: 22px; height: 22px; box-sizing: border-box;\">      <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>    </div>    <span style=\"font-family: 'Verdana', sans-serif; font-size: 14px; color: #1B1B1B; line-height: 1.5;\">CRM & ERP Integrations (Salesforce, HubSpot, SAP, Odoo, Oracle, Zoho)</span>  </div>  <div style=\"display: flex; align-items: start; gap: 12px;\">    <div style=\"background-color: rgba(229, 175, 43, 0.1); color: #E5AF2B; border-radius: 50%; padding: 4px; display: flex; align-items: center; justify-content: center; shrink: 0; width: 22px; height: 22px; box-sizing: border-box;\">      <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>    </div>    <span style=\"font-family: 'Verdana', sans-serif; font-size: 14px; color: #1B1B1B; line-height: 1.5;\">Microsoft Power Platform (Power Apps, Power Automate, Power BI development)</span>  </div></div>"
              }
            }
