            {
              "id": "faq_heading_ba",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Automation FAQ",
                "header_size": "h2",
                "align": "center",
                "title_color": "#1B1B1B",
                "typography_typography": "custom",
                "typography_font_family": "Verdana",
                "typography_font_size": {
