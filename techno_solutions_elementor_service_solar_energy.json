              "id": "widget_metrics_se",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<div style=\"background: #0F2D63; border-radius: 16px; padding: 24px; margin-top: 30px; box-shadow: 0 15px 30px rgba(15, 45, 99, 0.12); color: #FFFFFF;\"><h4 style=\"font-family: 'Verdana', sans-serif; font-size: 16px; font-weight: 700; color: #E5AF2B; margin-bottom: 20px; text-transform: uppercase; letter-spacing: 1px;\">Efficiency Unleashed</h4>  <div style=\"display: flex; flex-direction: column; gap: 16px;\">    <div>      <div style=\"font-size: 28px; font-weight: 700; font-family: 'Verdana', sans-serif; color: #FFFFFF;\">Up to 85%</div>      <div style=\"font-size: 12px; color: rgba(255, 255, 255, 0.7); font-family: 'Verdana', sans-serif; margin-top: 2px;\">Electricity Savings</div>    </div>    <div style=\"height: 1px; background: rgba(255, 255, 255, 0.1);\"></div>    <div>      <div style=\"font-size: 28px; font-weight: 700; font-family: 'Verdana', sans-serif; color: #FFFFFF;\">25+ Years</div>      <div style=\"font-size: 12px; color: rgba(255, 255, 255, 0.7); font-family: 'Verdana', sans-serif; margin-top: 2px;\">Panel Lifetime</div>    </div>    <div style=\"height: 1px; background: rgba(255, 255, 255, 0.1);\"></div>    <div>      <div style=\"font-size: 28px; font-weight: 700; font-family: 'Verdana', sans-serif; color: #FFFFFF;\">4.5 Years</div>      <div style=\"font-size: 12px; color: rgba(255, 255, 255, 0.7); font-family: 'Verdana', sans-serif; margin-top: 2px;\">Avg Payback Period</div>    </div>  </div></div>"
