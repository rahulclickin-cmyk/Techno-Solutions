{
  "version": "0.4",
  "title": "Techno-Solutions Footer - Elementor Template",
  "type": "section",
  "content": [
    {
      "id": "footer_section",
      "elType": "section",
      "isInner": false,
      "settings": {
        "background_background": "classic",
        "background_color": "#06183B",
        "padding": {
          "unit": "px",
          "top": "80",
          "right": "40",
          "bottom": "50",
          "left": "40",
          "isLinked": false
        }
      },
      "elements": [
        {
          "id": "footer_col1",
          "elType": "column",
          "settings": {
            "_column_size": 40
          },
          "elements": [
            {
              "id": "footer_logo",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "TECHNO-SOLUTIONS<span style='color: #E5AF2B;'>.</span>",
                "header_size": "h3",
                "title_color": "#FFFFFF",
                "typography_typography": "custom",
                "typography_font_family": "Playfair Display",
                "typography_font_weight": "800",
                "typography_font_size": {
                  "unit": "px",
                  "size": 24
                }
              }
            },
            {
              "id": "footer_desc",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style='color: #A0AEC0; font-size: 14px; margin-top: 15px;'>Leading technology consulting and strategic solutions provider in Delhi NCR. Empowering enterprises and SMEs with AI, Blockchain, Automation, Clean Energy, and Smart Infrastructure.</p><p style='color: #E5AF2B; font-weight: 700; font-size: 13px; margin-top: 15px;'>📍 Founder: Sanjeev Goel</p>"
              }
