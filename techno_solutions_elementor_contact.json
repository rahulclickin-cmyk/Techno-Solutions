              "settings": {
                "editor": "<div style='background-color: #F8F9FC; border: 1px solid #ECECEC; padding: 30px; border-radius: 16px; margin-top: 25px;'><h4 style='margin: 0 0 15px 0; font-family: \"Playfair Display\"; font-size: 18px; color: #1B1B1B;'>Contact Details</h4><div style='font-size: 14px; color: #5B6470; line-height: 1.8;'><p style='margin: 8px 0;'><strong>👤 Chief Consultant:</strong> Sanjeev Goel</p><p style='margin: 8px 0;'><strong>📞 Phone Number:</strong> +91 9811841782</p><p style='margin: 8px 0;'><strong>✉️ Email Address:</strong> info2sanjeev@gmail.com</p><p style='margin: 8px 0;'><strong>📍 Head Office:</strong> 218 AGCR Enclave, Near Karkardoma Metro Station, Delhi 110092 | India</p></div></div>"
              }
            }
          ]
        },
