            {
              "id": "widget_metrics_sh",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<div style=\"background: #0F2D63; border-radius: 16px; padding: 24px; margin-top: 30px; box-shadow: 0 15px 30px rgba(15, 45, 99, 0.12); color: #FFFFFF;\"><h4 style=\"font-family: 'Verdana', sans-serif; font-size: 16px; font-weight: 700; color: #E5AF2B; margin-bottom: 20px; text-transform: uppercase; letter-spacing: 1px;\">Home Ecosystem Metrics</h4>  <div style=\"display: flex; flex-direction: column; gap: 16px;\">    <div>      <div style=\"font-size: 28px; font-weight: 700; font-family: 'Verdana', sans-serif; color: #FFFFFF;\">7 Steps</div>      <div style=\"font-size: 12px; color: rgba(255, 255, 255, 0.7); font-family: 'Verdana', sans-serif; margin-top: 2px;\">Installation Process</div>    </div>    <div style=\"height: 1px; background: rgba(255, 255, 255, 0.1);\"></div>    <div>      <div style=\"font-size: 28px; font-weight: 700; font-family: 'Verdana', sans-serif; color: #FFFFFF;\">Alexa/Google</div>      <div style=\"font-size: 12px; color: rgba(255, 255, 255, 0.7); font-family: 'Verdana', sans-serif; margin-top: 2px;\">Voice Enabled</div>    </div>    <div style=\"height: 1px; background: rgba(255, 255, 255, 0.1);\"></div>    <div>      <div style=\"font-size: 28px; font-weight: 700; font-family: 'Verdana', sans-serif; color: #FFFFFF;\">Mesh Wi-Fi</div>      <div style=\"font-size: 12px; color: rgba(255, 255, 255, 0.7); font-family: 'Verdana', sans-serif; margin-top: 2px;\">Seamless Cover</div>    </div>  </div></div>"
              }
            }
          ]
