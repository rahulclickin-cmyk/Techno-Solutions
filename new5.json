              "widgetType": "text-editor",
              "settings": {
                "editor": "<div class=\"stats-card-hover\" style=\"display: flex; flex-direction: column; align-items: center; text-align: center; padding: 30px 20px; border-radius: 16px; border: 1px solid rgba(255, 255, 255, 0.08); background-color: rgba(255, 255, 255, 0.03); cursor: pointer; height: 100%; box-sizing: border-box;\">\n  <div class=\"stats-icon-hover\" style=\"display: flex; align-items: center; justify-content: center; width: 60px; height: 60px; border-radius: 50%; background-color: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1); margin-bottom: 16px; color: #E5AF2B;\">\n    <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2\"/><circle cx=\"9\" cy=\"7\" r=\"4\"/><path d=\"M22 21v-2a4 4 0 0 0-3-3.87\"/><path d=\"M16 3.13a4 4 0 0 1 0 7.75\"/></svg>\n  </div>\n  <div style=\"font-family: 'Playfair Display', serif; font-size: 38px; font-weight: 700; color: #FFFFFF; line-height: 1.2;\">\n    220<span style=\"color: #E5AF2B; font-family: 'Inter', sans-serif;\">+</span>\n  </div>\n  <div style=\"font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px; color: rgba(255, 255, 255, 0.7); margin-top: 8px;\">\n    Enterprise Clients\n  </div>\n</div>"
