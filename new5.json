      "elements": [
        {
          "id": "column_about_text_details",
          "elType": "column",
          "settings": {
            "_column_size": 50
          },
          "elements": [
            {
              "id": "widget_about_badge_elementor",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<div style=\"display: inline-flex; align-items: center; gap: 8px; padding: 6px 16px; border-radius: 30px; background-color: rgba(15, 45, 99, 0.05); border: 1px solid rgba(15, 45, 99, 0.1); color: #0F2D63; font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 20px;\">\n  <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#E5AF2B\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/></svg>\n  ABOUT TECHNO-SOLUTIONS\n</div>"
              }
            },
            {
              "id": "widget_about_heading_elementor",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Your Trusted Technology Partner",
                "header_size": "h2",
                "title_color": "#1B1B1B",
                "typography_typography": "custom",
                "typography_font_family": "Playfair Display",
                "typography_font_size": {
                  "unit": "px",
                  "size": 42
                },
                "typography_font_weight": "700",
                "typography_line_height": {
                  "size": 1.2
                }
              }
            },
            {
              "id": "widget_about_desc_paragraph",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p style=\"font-family: 'Inter', sans-serif; font-size: 15px; color: #5B6470; line-height: 1.7; margin: 15px 0 24px 0;\">Techno-Solutions is a leading Digital Transformation company helping organizations embrace the future through intelligent technology solutions. We combine business consulting, automation, Artificial Intelligence, blockchain technologies, IoT, renewable energy, and smart infrastructure to deliver measurable business outcomes.</p>\n\n<div style=\"border-left: 4px solid #E5AF2B; padding: 12px 18px; background-color: #F8F9FC; border-radius: 0 12px 12px 0; margin-bottom: 28px;\">\n  <p style=\"font-family: 'Inter', sans-serif; font-size: 14px; font-style: italic; font-weight: 600; color: #1B1B1B; margin: 0; line-height: 1.5;\">Our mission is simple: Helping organizations become faster, smarter, and more profitable through technology.</p>\n</div>"
              }
            },
            {
              "id": "widget_about_features_grid",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<div style=\"display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 16px; margin-bottom: 32px;\">\n  <!-- Bullet 1 -->\n  <div style=\"display: flex; align-items: start; gap: 10px;\">\n    <div style=\"background-color: rgba(229, 175, 43, 0.1); color: #E5AF2B; border-radius: 50%; padding: 3px; display: flex; align-items: center; justify-content: center; shrink: 0; width: 22px; height: 22px; box-sizing: border-box;\">\n      <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>\n    </div>\n    <span style=\"font-family: 'Inter', sans-serif; font-size: 13px; font-weight: 600; color: #1B1B1B; line-height: 1.4;\">Custom Business Automation & Enterprise ERP APIs</span>\n  </div>\n  \n  <!-- Bullet 2 -->\n  <div style=\"display: flex; align-items: start; gap: 10px;\">\n    <div style=\"background-color: rgba(229, 175, 43, 0.1); color: #E5AF2B; border-radius: 50%; padding: 3px; display: flex; align-items: center; justify-content: center; shrink: 0; width: 22px; height: 22px; box-sizing: border-box;\">\n      <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>\n    </div>\n    <span style=\"font-family: 'Inter', sans-serif; font-size: 13px; font-weight: 600; color: #1B1B1B; line-height: 1.4;\">Generative AI Strategy & Agentic Automations</span>\n  </div>\n  \n  <!-- Bullet 3 -->\n  <div style=\"display: flex; align-items: start; gap: 10px;\">\n    <div style=\"background-color: rgba(229, 175, 43, 0.1); color: #E5AF2B; border-radius: 50%; padding: 3px; display: flex; align-items: center; justify-content: center; shrink: 0; width: 22px; height: 22px; box-sizing: border-box;\">\n      <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>\n    </div>\n    <span style=\"font-family: 'Inter', sans-serif; font-size: 13px; font-weight: 600; color: #1B1B1B; line-height: 1.4;\">Smart IoT Infrastructure & Smart Home Integration</span>\n  </div>\n  \n  <!-- Bullet 4 -->\n  <div style=\"display: flex; align-items: start; gap: 10px;\">\n    <div style=\"background-color: rgba(229, 175, 43, 0.1); color: #E5AF2B; border-radius: 50%; padding: 3px; display: flex; align-items: center; justify-content: center; shrink: 0; width: 22px; height: 22px; box-sizing: border-box;\">\n      <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>\n    </div>\n    <span style=\"font-family: 'Inter', sans-serif; font-size: 13px; font-weight: 600; color: #1B1B1B; line-height: 1.4;\">High-Conversion Solar Grid & Battery Storage Systems</span>\n  </div>\n</div>"
              }
            },
            {
              "id": "widget_about_certifications",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<div style=\"display: flex; flex-wrap: wrap; align-items: center; gap: 24px; padding-top: 24px; border-top: 1px solid #ECECEC;\">\n  <!-- Cert 1 -->\n  <div style=\"display: flex; align-items: center; gap: 12px;\">\n    <div style=\"width: 42px; height: 42px; border-radius: 50%; background-color: rgba(15, 45, 99, 0.05); display: flex; align-items: center; justify-content: center; color: #0F2D63;\">\n      <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"8\" r=\"7\"/><polyline points=\"8.21 13.89 7 23 12 20 17 23 15.79 13.88\"/></svg>\n    </div>\n    <div>\n      <p style=\"font-family: 'Inter', sans-serif; font-size: 13px; font-weight: 700; color: #1B1B1B; margin: 0;\">ISO 27001 Certified</p>\n      <p style=\"font-family: 'Inter', sans-serif; font-size: 10px; color: #5B6470; margin: 2px 0 0 0;\">Security Compliant Code</p>\n    </div>\n  </div>\n  \n  <!-- Vertical Divider -->\n  <div style=\"width: 1px; height: 32px; background-color: #ECECEC; display: inline-block;\"></div>\n  \n  <!-- Cert 2 -->\n  <div style=\"display: flex; align-items: center; gap: 12px;\">\n    <div style=\"width: 42px; height: 42px; border-radius: 50%; background-color: rgba(229, 175, 43, 0.1); display: flex; align-items: center; justify-content: center; color: #0F2D63;\">\n      <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#0F2D63\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2\"/><circle cx=\"9\" cy=\"7\" r=\"4\"/><path d=\"M22 21v-2a4 4 0 0 0-3-3.87\"/><path d=\"M16 3.13a4 4 0 0 1 0 7.75\"/></svg>\n    </div>\n    <div>\n      <p style=\"font-family: 'Inter', sans-serif; font-size: 13px; font-weight: 700; color: #1B1B1B; margin: 0;\">Client-Authoritative</p>\n      <p style=\"font-family: 'Inter', sans-serif; font-size: 10px; color: #5B6470; margin: 2px 0 0 0;\">Zero Vendor Lock-In</p>\n    </div>\n  </div>\n</div>"
              }
            }
          ]
        },
        {
          "id": "column_about_media_visuals",
          "elType": "column",
          "settings": {
            "_column_size": 50
          },
          "elements": [
            {
              "id": "widget_about_video_frame",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<div style=\"position: relative; width: 100%; box-sizing: border-box; padding-bottom: 40px; padding-left: 30px;\">\n  <!-- Main Office Image Frame -->\n  <div class=\"video-container\" style=\"position: relative; border-radius: 22px; overflow: hidden; box-shadow: 0 25px 60px rgba(0, 0, 0, 0.1); border: 1px solid #ECECEC; aspect-ratio: 4/3; width: 100%; transition: all 0.5s ease;\">\n    <img src=\"https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&w=800&q=80\" alt=\"Luxury Corporate Office Interior\" style=\"width: 100%; height: 100%; object-fit: cover; transition: transform 0.7s ease; display: block;\" />\n    \n    <!-- Blue tint overlay -->\n    <div style=\"position: absolute; inset: 0; background-color: rgba(15, 45, 99, 0.2); transition: opacity 0.3s ease;\"></div>\n    \n    <!-- Centered Play Button Overlay with Pulse rings -->\n    <div style=\"position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;\">\n      <div class=\"play-pulse play-btn\" style=\"width: 80px; height: 80px; border-radius: 50%; background-color: #FFFFFF; color: #0F2D63; box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15); display: flex; align-items: center; justify-content: center; transition: all 0.3s ease; cursor: pointer;\">\n        <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"currentColor\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" style=\"margin-left: 4px;\"><polygon points=\"5 3 19 12 5 21 5 3\"/></svg>\n      </div>\n    </div>\n    \n    <!-- Inner Thin Border for 3D layout -->\n    <div style=\"position: absolute; inset: 16px; border: 1px solid rgba(255, 255, 255, 0.2); pointer-events: none; border-radius: 18px;\"></div>\n  </div>\n  \n  <!-- Floating Experience Card overlapping the bottom-left -->\n  <div class=\"floating-card-anim\" style=\"position: absolute; bottom: -10px; left: 0px; background-color: #FFFFFF; padding: 20px; border-radius: 20px; box-shadow: 0 20px 40px rgba(0, 0, 0, 0.12); border: 1px solid #ECECEC; max-width: 320px; display: flex; align-items: start; gap: 16px; box-sizing: border-box; z-index: 10;\">\n    <div style=\"padding: 12px; border-radius: 12px; background-color: rgba(229, 175, 43, 0.1); color: #E5AF2B; display: flex; align-items: center; justify-content: center; shrink: 0; width: 44px; height: 44px; box-sizing: border-box;\">\n      <svg xmlns=\"http://www.w3.org/2000/svg\" width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M22 11.08V12a10 10 0 1 1-5.93-9.14\"/><polyline points=\"22 4 12 14.01 9 11.01\"/></svg>\n    </div>\n    <div>\n      <p style=\"font-family: 'Playfair Display', serif; font-weight: 700; font-size: 18px; color: #0F2D63; margin: 0 0 4px 0; line-height: 1.2;\">100% Client Retention</p>\n      <p style=\"font-family: 'Inter', sans-serif; font-size: 11px; color: #5B6470; margin: 0; line-height: 1.4;\">All custom-engineered nodes running at zero unexpected interruptions since 2021.</p>\n    </div>\n  </div>\n</div>"
              }
            }
          ]
        }
      ]
    }
  ]
}
